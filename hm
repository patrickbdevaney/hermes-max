#!/usr/bin/env bash
# hm — one ergonomic terminal-native command over the whole hermes-max stack.
#
# Pure DISPATCH over the existing scripts — every verb maps to a scripts/*.sh that
# STILL runs directly on its own (`./scripts/start-all.sh` etc. unchanged). `hm` is
# sugar, the scripts are the substance. Runnable as `./hm` from the repo root, or
# install onto PATH (`hm install`, or via bootstrap.sh).
#
#   hm up [--MODE]        start all MCPs (+ embed/rerank hint)         scripts/start-all.sh
#                         MODE = --local|--free|--full|--frontier (default --full);
#                         the cloud-tier ceiling, presence-gated with fall-through
#   hm down               stop everything (PID + port fallback)        scripts/stop-all.sh
#   hm restart [srv|all]  restart one server or all                    scripts/restart.sh
#   hm status             UP/DOWN · port · PID · uptime · health       scripts/status.sh
#   hm watch              live tool-call stream                        scripts/watch.sh
#   hm logs [server]      tail a server's log (or the live log)        ~/.hermes-max/logs/
#   hm run "task"         launch hermes with a task                    hermes
#   hm snapshot <name>    snapshot RAG+KG+corpus stores                scripts/snapshot-stores.sh
#   hm restore <name>     restore a named snapshot                     scripts/restore-stores.sh
#   hm dev [--MODE]       the tmux cockpit (hermes + watch + status)   (this script)
#   hm attach             reattach to the running tmux cockpit         tmux attach
#   hm health             pass/fail healthcheck (for scripting)        scripts/healthcheck.sh
#   hm preflight          validate the whole stack before a task       scripts/preflight.sh
#                         (PASS/FAIL/WARN; auto-fixes; exit 1 on BLOCKING)
#   hm smoke              real ~15-min end-to-end agent proof           scripts/integration-smoke.sh
#   hm summary            per-task tool-call summary + bottleneck split scripts/run-summary.sh
#   hm bottleneck         full-vs-bare timing eval                     scripts/bottleneck-eval.sh
#   hm cost               conductor spend + Opus sparing proof         scripts/conductor-report.sh
#   hm eval [capability]  prove every feature works in the REAL agent  scripts/eval-battery.sh
#                         loop (asserts real effects); one capability if named
#   hm install            symlink hm onto PATH (~/.local/bin)
set -uo pipefail

HM_SELF="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
SCRIPTS="${REPO_ROOT}/scripts"
TMUX_SESSION="hermes-max"
LOG_DIR="${HERMES_MAX_LOG_DIR:-${HOME}/.hermes-max/logs}"
LOG_DIR="${LOG_DIR/#\~/$HOME}"

# In HM_PRINT mode, echo the command that WOULD run instead of executing it. Used
# by the smoke test to prove `hm <verb>` maps to the right standalone script,
# without side effects.
_dispatch() {
  if [ -n "${HM_PRINT:-}" ]; then echo "$*"; exit 0; fi
  exec "$@"
}

_port_up() { timeout 1 bash -c ">/dev/tcp/127.0.0.1/$1" 2>/dev/null; }

# Start the embed (:8002) + rerank (:8003) serves, backgrounded, if not already up.
# DEFAULT ON for the gpu_local profile (the model serves the dense lane + reranker);
# opt out with HM_WITH_EMBED=0 / HM_WITH_RERANK=0. On lean_cloud they stay off.
_start_serves() {
  local profile="${DEPLOY_PROFILE:-gpu_local}"
  local want_embed="${HM_WITH_EMBED:-}" want_rerank="${HM_WITH_RERANK:-}"
  if [ "${profile}" = "gpu_local" ]; then
    [ -z "${want_embed}" ]  && want_embed=1
    [ -z "${want_rerank}" ] && want_rerank=1
  fi
  mkdir -p "${LOG_DIR}"
  if [ "${want_embed}" = "1" ]; then
    if _port_up "${EMBED_PORT:-8002}"; then echo "  • embed already up on :${EMBED_PORT:-8002}"
    else echo "  • starting embed serve on :${EMBED_PORT:-8002} (background)"
         nohup "${REPO_ROOT}/serve-embed.sh" >>"${LOG_DIR}/embed.log" 2>&1 & fi
  fi
  if [ "${want_rerank}" = "1" ]; then
    if _port_up "${RERANK_PORT:-8003}"; then echo "  • rerank already up on :${RERANK_PORT:-8003}"
    else echo "  • starting rerank serve on :${RERANK_PORT:-8003} (background)"
         nohup "${REPO_ROOT}/serve-rerank.sh" >>"${LOG_DIR}/rerank.log" 2>&1 & fi
  fi
}

# ── conductor MODE system (--local | --free | --full | --frontier) ────────────
# Default --full. Each mode is a SUPERSET of the one below and is presence-gated:
# a tier whose required key is absent falls through to the next-lower tier, so the
# system always resolves to the highest tier whose keys are actually present. The
# mode is the CEILING; the conductor's per-subtask gating decides actual use.
HMX_ENV_FILE="${HMX_ENV_FILE:-${REPO_ROOT}/.env}"
HMX_MODE_FILE="${HERMES_MAX_STATE_DIR:-${HOME}/.hermes-max}/conductor/mode"
HMX_MODE_FILE="${HMX_MODE_FILE/#\~/$HOME}"

# A key is present if non-empty in the live shell env OR non-empty in .env.
_key_present() {
  local k="$1"
  [ -n "${!k:-}" ] && return 0
  grep -qE "^${k}=[^[:space:]#]" "${HMX_ENV_FILE}" 2>/dev/null
}
_paid_present() { _key_present DEEPINFRA_API_KEY || _key_present FIREWORKS_API_KEY \
  || _key_present TOGETHER_API_KEY || _key_present DEEPSEEK_API_KEY || _key_present MOONSHOT_API_KEY; }
_free_present() { _key_present CEREBRAS_API_KEY || _key_present GROQ_API_KEY || _key_present GEMINI_API_KEY; }

# Resolve a requested mode to the highest tier whose required key is present,
# warning (to stderr) on each fall-through. Echoes the effective mode on stdout.
_resolve_mode() {
  local m="$1"
  while :; do
    case "${m}" in
      frontier) _key_present ANTHROPIC_API_KEY && break
                echo "  ⚠ --frontier needs ANTHROPIC_API_KEY (absent) → falling back to --full (Opus tier OFF)" >&2; m=full ;;
      full)     _paid_present && break
                echo "  ⚠ --full needs a paid synth key (DeepInfra/Fireworks/Together/DeepSeek/Moonshot) (absent) → --free" >&2; m=free ;;
      free)     _free_present && break
                echo "  ⚠ --free needs a free key (Cerebras/Groq/Gemini) (absent) → --local" >&2; m=local ;;
      local)    break ;;
      *)        m=full ;;
    esac
  done
  echo "${m}"
}

_mode_tiers_line() {
  case "$1" in
    local)    echo "local only — fully sovereign, \$0 cloud" ;;
    free)     echo "local + free draft/steer (Cerebras/Groq/Gemini)" ;;
    full)     echo "local + free + DeepSeek V4 steer/synth (paid, ~\$10/mo)" ;;
    frontier) echo "local + free + DeepSeek + SPARING Opus 4.8 escalation (3-gated, ~\$12-15/mo)" ;;
  esac
}

# Apply a mode: resolve fall-through, persist to .env (backed up) + the live mode
# file, export for freshly-started servers. Sets HMX_MODE_CHANGED=1 if .env changed
# (the caller restarts the conductor so the running server picks up the new mode).
HMX_MODE_CHANGED=0
HMX_EFFECTIVE_MODE=""
_apply_mode() {
  local requested="${1:-full}" eff cur
  eff="$(_resolve_mode "${requested}")"
  HMX_EFFECTIVE_MODE="${eff}"
  mkdir -p "$(dirname "${HMX_MODE_FILE}")"
  printf '%s\n' "${eff}" > "${HMX_MODE_FILE}"
  cur="$(grep -E '^CONDUCTOR_MODE=' "${HMX_ENV_FILE}" 2>/dev/null | head -1 | sed 's/^CONDUCTOR_MODE=//; s/[[:space:]].*//')"
  if [ "${cur}" != "${eff}" ]; then
    if [ -f "${HMX_ENV_FILE}" ]; then
      cp -p "${HMX_ENV_FILE}" "${HMX_ENV_FILE}.bak.mode.$(date +%s 2>/dev/null || echo bak)" 2>/dev/null || true
      if grep -qE '^CONDUCTOR_MODE=' "${HMX_ENV_FILE}"; then
        sed -i "s@^CONDUCTOR_MODE=.*@CONDUCTOR_MODE=${eff}   # set by hm up (local/free/full/frontier)@" "${HMX_ENV_FILE}"
      else
        printf 'CONDUCTOR_MODE=%s   # set by hm up (local/free/full/frontier)\n' "${eff}" >> "${HMX_ENV_FILE}"
      fi
    fi
    HMX_MODE_CHANGED=1
  fi
  export CONDUCTOR_MODE="${eff}"
  if [ "${eff}" != "${requested}" ]; then
    echo "  • requested --${requested}, resolved to --${eff} (key fall-through)"
  fi
  echo "  ▸ conductor mode: ${eff} — $(_mode_tiers_line "${eff}")"
}

# Extract a --local|--free|--full|--frontier flag from args; echo the mode (or
# 'full' default). Other args are ignored (start-all takes none meaningfully).
_mode_from_args() {
  local m=full a
  for a in "$@"; do case "${a}" in
    --local) m=local ;; --free) m=free ;; --full) m=full ;; --frontier) m=frontier ;;
  esac; done
  echo "${m}"
}

usage() {
  sed -n '3,31p' "${HM_SELF}" | sed 's/^# \{0,1\}//'
}

_install() {
  local bindir="${HOME}/.local/bin"
  mkdir -p "${bindir}"
  ln -sf "${HM_SELF}" "${bindir}/hm"
  echo "✓ linked ${bindir}/hm -> ${HM_SELF}"
  case ":${PATH}:" in *":${bindir}:"*) : ;;
    *) echo "  note: ${bindir} is not on PATH — add it: export PATH=\"${bindir}:\$PATH\"" ;;
  esac
}

_attach() {
  if [ -n "${HM_PRINT:-}" ]; then echo "tmux attach -t ${TMUX_SESSION}"; exit 0; fi
  command -v tmux >/dev/null 2>&1 || { echo "✗ tmux not installed"; exit 1; }
  tmux has-session -t "${TMUX_SESSION}" 2>/dev/null || { echo "no '${TMUX_SESSION}' session — start it with: hm dev"; exit 1; }
  exec tmux attach -t "${TMUX_SESSION}"
}

# The one-command tmux cockpit: hermes pane + live-watch pane + status pane.
# Detachable, reattach-from-anywhere (hm attach), 24/7. If the session already
# exists, just attach. tmux absent → clear manual instructions (never a hard fail).
_dev() {
  if [ -n "${HM_PRINT:-}" ]; then echo "tmux new-session -s ${TMUX_SESSION} (hermes | watch | status)"; exit 0; fi
  if ! command -v tmux >/dev/null 2>&1; then
    cat <<EOF
tmux is not installed — the cockpit needs it. Install it (apt: 'sudo apt install tmux',
brew: 'brew install tmux'), or run the panes manually in three terminals:
  1) ${SCRIPTS}/start-all.sh        # bring the stack up
  2) ${SCRIPTS}/watch.sh            # live tool-call stream
  3) watch -n3 ${SCRIPTS}/status.sh # stack health
  4) hermes                         # the agent prompt
The individual scripts work without tmux — hm dev is only the convenience cockpit.
EOF
    exit 1
  fi
  # already running → just attach (from anywhere, incl. over the network)
  if tmux has-session -t "${TMUX_SESSION}" 2>/dev/null; then
    echo "• '${TMUX_SESSION}' already running — attaching"
    exec tmux attach -t "${TMUX_SESSION}"
  fi
  # conductor mode (default --full) before bringing the stack up
  _apply_mode "$(_mode_from_args "$@")"
  # pre-flight validation FIRST — auto-fixes the killers (timeouts, skills,
  # embed/rerank) and brings the stack up; BLOCKING failure aborts the cockpit so
  # we never launch the agent into a misconfigured stack. Override with HM_FORCE=1.
  if [ -f "${SCRIPTS}/preflight.sh" ]; then
    if ! "${SCRIPTS}/preflight.sh" --fix; then
      if [ -n "${HM_FORCE:-}" ]; then
        echo "  ⚠ preflight reported BLOCKING failures — continuing anyway (HM_FORCE=1)"
      else
        echo "  ✗ preflight found BLOCKING failures — fix them, or re-run with HM_FORCE=1 to override."
        exit 1
      fi
    fi
  fi
  # bring servers up if not already healthy (backgrounded inside start-all)
  "${SCRIPTS}/healthcheck.sh" >/dev/null 2>&1 || "${SCRIPTS}/start-all.sh" || true
  if [ "${HMX_MODE_CHANGED}" = "1" ] && timeout 1 bash -c ">/dev/tcp/127.0.0.1/${MCP_ESCALATION_PORT:-9105}" 2>/dev/null; then
    "${SCRIPTS}/restart.sh" escalation >/dev/null 2>&1 || true
  fi
  # embed + rerank serves (gpu_local default) so the cockpit's status pane shows them
  _start_serves || true
  # pane 1 (large): an interactive shell ready for `hermes`
  tmux new-session -d -s "${TMUX_SESSION}" -n cockpit -x 220 -y 50
  tmux send-keys -t "${TMUX_SESSION}" \
    "echo '── hermes pane — type: hermes ──'; command -v hermes >/dev/null && echo '(hermes ready)' || echo '(hermes not on PATH)'" C-m
  # pane 2: live watch stream
  tmux split-window -h -t "${TMUX_SESSION}"
  tmux send-keys -t "${TMUX_SESSION}" "${SCRIPTS}/watch.sh" C-m
  # pane 3: auto-refreshing status (use watch if present, else a sleep loop)
  tmux split-window -v -t "${TMUX_SESSION}"
  if command -v watch >/dev/null 2>&1; then
    tmux send-keys -t "${TMUX_SESSION}" "watch -t -n 4 ${SCRIPTS}/status.sh" C-m
  else
    tmux send-keys -t "${TMUX_SESSION}" \
      "while true; do clear; ${SCRIPTS}/status.sh; sleep 4; done" C-m
  fi
  tmux select-pane -t "${TMUX_SESSION}.0"
  [ -n "${HM_NO_ATTACH:-}" ] && { echo "✓ cockpit '${TMUX_SESSION}' started (detached). hm attach to join."; return 0; }
  exec tmux attach -t "${TMUX_SESSION}"
}

# Sourcing with HM_LIB_ONLY=1 defines the helper functions and stops before the
# dispatch — so the mode-resolution logic can be unit-tested in isolation.
if [ -n "${HM_LIB_ONLY:-}" ]; then return 0 2>/dev/null || exit 0; fi

cmd="${1:-}"; shift || true
case "${cmd}" in
  up)
    if [ -n "${HM_PRINT:-}" ]; then echo "${SCRIPTS}/start-all.sh"; exit 0; fi
    _apply_mode "$(_mode_from_args "$@")"
    # Raise Hermes' own MCP call timeouts (the 120s long-run killer) before the
    # stack comes up — idempotent, no-op once applied. Never fails `hm up`.
    [ -f "${SCRIPTS}/fix-hermes-timeouts.sh" ] && \
      "${SCRIPTS}/fix-hermes-timeouts.sh" || true
    "${SCRIPTS}/start-all.sh"
    # If the conductor was already running, restart it so it picks up the new mode
    # (mode is read from CONDUCTOR_MODE in .env at launch). No-op if mode unchanged.
    if [ "${HMX_MODE_CHANGED}" = "1" ] && timeout 1 bash -c ">/dev/tcp/127.0.0.1/${MCP_ESCALATION_PORT:-9105}" 2>/dev/null; then
      echo "  • mode changed → restarting conductor (escalation) to apply it"
      "${SCRIPTS}/restart.sh" escalation >/dev/null 2>&1 || true
    fi
    # embed (:8002) + rerank (:8003) serves auto-start with the stack on gpu_local
    # (the dense lane + reranker); opt out with HM_WITH_EMBED=0 / HM_WITH_RERANK=0.
    _start_serves
    ;;
  down)        _dispatch "${SCRIPTS}/stop-all.sh" "$@" ;;
  restart)     _dispatch "${SCRIPTS}/restart.sh" "$@" ;;
  status)      _dispatch "${SCRIPTS}/status.sh" "$@" ;;
  watch)       _dispatch "${SCRIPTS}/watch.sh" "$@" ;;
  health)      _dispatch "${SCRIPTS}/healthcheck.sh" "$@" ;;
  preflight)   _dispatch "${SCRIPTS}/preflight.sh" "$@" ;;
  smoke)       _dispatch "${SCRIPTS}/integration-smoke.sh" "$@" ;;
  summary)     _dispatch "${SCRIPTS}/run-summary.sh" "$@" ;;
  bottleneck)  _dispatch "${SCRIPTS}/bottleneck-eval.sh" "$@" ;;
  cost)        _dispatch "${SCRIPTS}/conductor-report.sh" "$@" ;;
  eval)        _dispatch "${SCRIPTS}/eval-battery.sh" "$@" ;;
  snapshot)    _dispatch "${SCRIPTS}/snapshot-stores.sh" "$@" ;;
  restore)     _dispatch "${SCRIPTS}/restore-stores.sh" "$@" ;;
  logs)
    srv="${1:-live}"
    if [ "${srv}" = "live" ]; then f="${LOG_DIR}/live.log"; else f="${LOG_DIR}/${srv#mcp-}.log"; fi
    if [ -n "${HM_PRINT:-}" ]; then echo "tail -F ${f}"; exit 0; fi
    [ -f "${f}" ] || { echo "no log at ${f}"; exit 1; }
    exec tail -n "${HM_LOG_LINES:-60}" -F "${f}"
    ;;
  run)
    if [ -n "${HM_PRINT:-}" ]; then echo "hermes $*"; exit 0; fi
    command -v hermes >/dev/null 2>&1 || { echo "✗ 'hermes' not on PATH — install/activate Hermes first."; exit 127; }
    exec hermes "$@"
    ;;
  dev)     _dev "$@" ;;
  attach)  _attach ;;
  install) _install ;;
  ""|-h|--help|help) usage ;;
  *) echo "hm: unknown verb '${cmd}'"; echo; usage; exit 2 ;;
esac
