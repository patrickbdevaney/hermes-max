# The full surface — extracted from the header comment block (DRY: the comment is
# the authoritative per-verb doc), from line 3 up to the `set -uo pipefail` line.
_help_all() {
  sed -n '3,/^set -uo pipefail/p' "${HM_SELF}" | sed -e '/^set -uo pipefail/d' -e 's/^# \{0,1\}//'
}

# Route `hm help` / `hm` (no args) to the short help; `hm help --all` to the full one.
usage() {
  case " $* " in *" --all "*|*" -a "*|*" all "*) _help_all ;; *) _help_short ;; esac
}

# One-paragraph help for an individual verb (`hm <verb> --help`).
_verb_help() {
  case "$1" in
    up)         echo "hm up [--free|--full|--MODE] [--free-uplift] — start the whole stack in a profile/mode. --free = Profile A (you own a GPU: local model executes, free planner); --full = Profile B (no GPU: economic API drives and plans). Advanced modes: --full-local --frontier-local --frontier --local (docs/modes.md). Prints which providers are present, which roles are satisfiable, the Hermes backend set, and any roster warnings." ;;
    down)       echo "hm down — stop every MCP server (by PID file, port fallback) and the embed/rerank serves. Idempotent; confirms every port is free." ;;
    restart)    echo "hm restart [server|all] — stop then start one named server (e.g. 'hm restart research') or the whole stack, re-running health." ;;
    status)     echo "hm status — the single 'is it OK and what's it costing' view: per-server UP/DOWN · port · PID · uptime · health, plus the active mode and today's spend." ;;
    mode)       echo "hm mode [name|--list] — show or switch the cost/quality posture live (no restart). Names: $(_inf list 2>/dev/null | sed -n '2,7p' | awk '{print $1}' | tr '\n' ' '). See docs/modes.md." ;;
    dev)        echo "hm dev [--MODE] — the one-window tmux cockpit: a hermes pane, a live activity (watch) pane, and a compact status pane (mode + spend). Detachable; reattach with 'hm attach'. tmux absent → prints manual instructions." ;;
    attach)     echo "hm attach — reattach to the running 'hermes-max' tmux cockpit started by hm dev." ;;
    run)        echo "hm run \"task\" — launch the Hermes agent on a task (exec's 'hermes'). Equivalent to running 'hermes' directly." ;;
    ui-test)    echo "hm ui-test — PART V actuation equivalence test: drives a real bounded agent turn through the web UI's own API headlessly and asserts every action surfaced in the SSE visual-flow, real artifacts landed on disk, verify went green, the handback fired, a follow-up turn actuated, and zero secrets leaked. Proves the UI ACTUATES the agent (a complete replacement for hm dev + hermes), not just visualizes it. Runs in --mode free; needs the stack up (hm up)." ;;
    ui)         echo "hm ui [--port N] [--no-open] [--token [T]] — open the localhost web view: L0 ambient + L1 timeline + L2 span tree + live cost, fed by the existing livelog/ledger/OTLP over SSE. Auto-opens your browser and prints one line (http://localhost:7080). Port is sticky (~/.hermes-max/ui.conf; next free port if taken). No token needed on localhost — hardened by 127.0.0.1 bind + Origin/Host checks + a SameSite CSRF cookie. --token adds a bearer for remote/Tailscale exposure. Read-only. Ctrl-C to stop." ;;
    cost)       echo "hm cost [today|week|month] — spend breakdown at \$0.000000 precision: by provider/model/role, the free-vs-paid split, and remaining daily free budget per model." ;;
    health)     echo "hm health — pass/fail healthcheck for scripting: endpoints reachable, providers present, and the full model-roster confirmation (warns on a deprecated/missing id; never gates)." ;;
    preflight)  echo "hm preflight — validate the whole stack before a task (PASS/FAIL/WARN); auto-fixes the common killers; exit 1 on a BLOCKING failure." ;;
    watch)      echo "hm watch — the raw live tool-call stream: every call, heartbeat, fallback, and routing decision. (Cockpit uses this; for debugging.)" ;;
    observe)    echo "hm observe — the live waterfall view of where wall-clock time actually went. (For debugging.)" ;;
    logs)       echo "hm logs [server] — tail a server's log under ~/.hermes-max/logs/ (or the live log with no arg)." ;;
    smoke)      echo "hm smoke — a real ~15-minute end-to-end agent proof that drives every component once." ;;
    regression) echo "hm regression — the regression eval gate." ;;
    summary)    echo "hm summary — per-task tool-call summary + the inference/tool-work/artificial bottleneck split." ;;
    bottleneck) echo "hm bottleneck — run the SAME task FULL vs BARE and print both timing splits → bottleneck_report.md." ;;
    eval)       echo "hm eval [capability] — prove every feature works in a REAL agent turn (asserts a real artifact effect, not a 200). Name one capability for fast iteration." ;;
    snapshot)   echo "hm snapshot <name> — snapshot the RAG index + KG db + corpus stores to ~/.hermes-max/snapshots/<name>." ;;
    restore)    echo "hm restore <name> — restore a named store snapshot (the current state is auto-backed-up first)." ;;
    setup)      echo "hm setup — first-run wiring: copy the config trinity into ~/.hermes-max/ and print which providers are present." ;;
    install)    echo "hm install — symlink hm onto PATH (~/.local/bin/hm)." ;;
    *)          return 1 ;;
  esac
}

_install() {
  local bindir="${HOME}/.local/bin"
  mkdir -p "${bindir}"
  ln -sf "${HM_SELF}" "${bindir}/hm"
  echo "✓ linked ${bindir}/hm -> ${HM_SELF}"
  case ":${PATH}:" in *":${bindir}:"*) : ;;
    *) echo "  note: ${bindir} is not on PATH — add it: export PATH=\"${bindir}:\$PATH\"" ;;
  esac
}

_attach() {
  if [ -n "${HM_PRINT:-}" ]; then echo "tmux attach -t ${TMUX_SESSION}"; exit 0; fi
  command -v tmux >/dev/null 2>&1 || { echo "✗ tmux not installed"; exit 1; }
  tmux has-session -t "${TMUX_SESSION}" 2>/dev/null || { echo "no '${TMUX_SESSION}' session — start it with: hm dev"; exit 1; }
  exec tmux attach -t "${TMUX_SESSION}"
}

# Resolve the sticky web-UI port (ui.conf, else default 7080).
_ui_port() {
  local conf="${HERMES_MAX_CONFIG_DIR:-${HOME}/.hermes-max}/ui.conf"
  if [ -f "${conf}" ]; then
    local p; p="$(grep -oE '[0-9]{2,5}' "${conf}" 2>/dev/null | head -1)"
    [ -n "${p}" ] && { echo "${p}"; return; }
  fi
  echo "7080"
}

# Stop the backgrounded web UI started by `hm dev` (by pidfile).
_stop_ui() {
  local f="${HMX_RUN_DIR}/ui.pid"
  if [ -f "${f}" ]; then
    kill "$(cat "${f}" 2>/dev/null)" 2>/dev/null || true
    rm -f "${f}"
    echo "  • web UI stopped"
  fi
}

# `hm dev` — daemonize the stack: background MCP servers (start-all, pidfiled) + the
# web UI (backgrounded, pidfile), then RETURN to the shell. No tmux, no blocking.
# Native execution is `hm run` (exec into hermes); the tmux cockpit is `hm cockpit`.
_dev_daemon() {
  if [ -n "${HM_PRINT:-}" ]; then echo "${SCRIPTS}/start-all.sh + ui.server (daemon)"; exit 0; fi
  # 1. MCP stack up (idempotent; start-all backgrounds each server with a pidfile)
  "${SCRIPTS}/healthcheck.sh" >/dev/null 2>&1 || "${SCRIPTS}/start-all.sh" || true
  _start_serves 2>/dev/null || true
  # 2. web UI backgrounded with a pidfile (skip if already up)
  mkdir -p "${HMX_RUN_DIR}"
  local uipid="${HMX_RUN_DIR}/ui.pid" port; port="$(_ui_port)"
  if [ -f "${uipid}" ] && kill -0 "$(cat "${uipid}" 2>/dev/null)" 2>/dev/null; then
    echo "  • web UI already running (pid $(cat "${uipid}"))"
  else
    # nohup exec-replaces itself with python, so $! is python's real pid (PYTHONPATH
    # makes `ui`/`lib` importable without changing hm's cwd).
    HMX_UI_NO_OPEN=1 PYTHONPATH="${REPO_ROOT}:${PYTHONPATH:-}" \
      nohup python3 -m ui.server --no-open --port "${port}" >"${LOG_DIR}/ui.log" 2>&1 &
    echo $! > "${uipid}"
  fi
  # 3. report + return (no blocking)
  echo "✓ Stack ready.  Web UI: http://localhost:${port}"
  echo "  next:  hm run \"<task>\"  ·  hm status  ·  hm stop  ·  hm cockpit (tmux view)"
}

# The one-command tmux cockpit: hermes pane + live-watch pane + status pane.
# Detachable, reattach-from-anywhere (hm attach), 24/7. If the session already
# exists, just attach. tmux absent → clear manual instructions (never a hard fail).
_dev() {
  if [ -n "${HM_PRINT:-}" ]; then echo "tmux new-session -s ${TMUX_SESSION} (hermes | watch | status)"; exit 0; fi
  if ! command -v tmux >/dev/null 2>&1; then
    cat <<EOF
tmux is not installed — the cockpit needs it. Install it (apt: 'sudo apt install tmux',
brew: 'brew install tmux'), or run the panes manually in three terminals:
  1) ${SCRIPTS}/start-all.sh        # bring the stack up
  2) ${SCRIPTS}/watch.sh            # live tool-call stream
  3) watch -n3 ${SCRIPTS}/status.sh # stack health
  4) hermes                         # the agent prompt
The individual scripts work without tmux — hm dev is only the convenience cockpit.
EOF
    exit 1
  fi
  # already running → just attach (from anywhere, incl. over the network)
  if tmux has-session -t "${TMUX_SESSION}" 2>/dev/null; then
    echo "• '${TMUX_SESSION}' already running — attaching"
    exec tmux attach -t "${TMUX_SESSION}"
  fi
  # posture mode (explicit --<mode> switches; else keep the persisted posture)
  _m="$(_inf_mode_from_args "$@")"
  if [ -n "${_m}" ]; then _apply_inf_mode "${_m}"
  else _apply_inf_mode "$(_inf name 2>/dev/null || echo free)"; fi
  # pre-flight validation FIRST — auto-fixes the killers (timeouts, skills,
  # embed/rerank) and brings the stack up; BLOCKING failure aborts the cockpit so
  # we never launch the agent into a misconfigured stack. Override with HM_FORCE=1.
  if [ -f "${SCRIPTS}/preflight.sh" ]; then
    if ! "${SCRIPTS}/preflight.sh" --fix; then
      if [ -n "${HM_FORCE:-}" ]; then
        echo "  ⚠ preflight reported BLOCKING failures — continuing anyway (HM_FORCE=1)"
      else
        echo "  ✗ preflight found BLOCKING failures — fix them, or re-run with HM_FORCE=1 to override."
        exit 1
      fi
    fi
  fi
  # bring servers up if not already healthy (backgrounded inside start-all)
  "${SCRIPTS}/healthcheck.sh" >/dev/null 2>&1 || "${SCRIPTS}/start-all.sh" || true
  if [ "${HMX_MODE_CHANGED}" = "1" ] && timeout 1 bash -c ">/dev/tcp/127.0.0.1/${MCP_ESCALATION_PORT:-9105}" 2>/dev/null; then
    "${SCRIPTS}/restart.sh" escalation >/dev/null 2>&1 || true
  fi
  # embed + rerank serves (gpu_local default) so the cockpit's status pane shows them
  _start_serves || true
  # cockpit cost baseline: snapshot today's spend now so the status pane can show
  # "this session" as a delta (best-effort; absent → session reads as today).
  mkdir -p "${HOME}/.hermes-max/ui" 2>/dev/null || true
  ( cd "${REPO_ROOT}" && python3 -c "from lib.inference import ledger; print(ledger.report('today')['total_usd'])" 2>/dev/null ) \
    > "${HOME}/.hermes-max/ui/cockpit_base" 2>/dev/null || true
  # pane 1 (large): an interactive shell ready for `hermes`
  tmux new-session -d -s "${TMUX_SESSION}" -n cockpit -x 220 -y 50
  tmux send-keys -t "${TMUX_SESSION}" \
    "echo '── hermes pane — type: hermes ──'; command -v hermes >/dev/null && echo '(hermes ready)' || echo '(hermes not on PATH)'" C-m
  # pane 2: the structured live activity stream (server · tool · input · status ·
  # timing + research fan-out sub-entries); falls back to the plain watch tail.
  tmux split-window -h -t "${TMUX_SESSION}"
  tmux send-keys -t "${TMUX_SESSION}" \
    "python3 ${SCRIPTS}/cockpit_livelog.py 2>/dev/null || ${SCRIPTS}/watch.sh" C-m
  # pane 3: auto-refreshing status (use watch if present, else a sleep loop)
  tmux split-window -v -t "${TMUX_SESSION}"
  # status pane: the live run-context block (mode · cost · task · phase · rung ·
  # elapsed) on top, then the stack server table.
  _statpane="python3 ${SCRIPTS}/cockpit_status.py 2>/dev/null || (cd ${REPO_ROOT} && python3 -m lib.inference.modes_cli status-line); ${SCRIPTS}/status.sh"
  if command -v watch >/dev/null 2>&1; then
    tmux send-keys -t "${TMUX_SESSION}" "watch -t -n 4 '${_statpane}'" C-m
  else
    tmux send-keys -t "${TMUX_SESSION}" \
      "while true; do clear; ${_statpane}; sleep 4; done" C-m
  fi
  tmux select-pane -t "${TMUX_SESSION}.0"
  [ -n "${HM_NO_ATTACH:-}" ] && { echo "✓ cockpit '${TMUX_SESSION}' started (detached). hm attach to join."; return 0; }
  exec tmux attach -t "${TMUX_SESSION}"
}

# Sourcing with HM_LIB_ONLY=1 defines the helper functions and stops before the
# dispatch — so the mode-resolution logic can be unit-tested in isolation.
if [ -n "${HM_LIB_ONLY:-}" ]; then return 0 2>/dev/null || exit 0; fi

cmd="${1:-}"; shift || true

# `hm <verb> --help` → one-paragraph verb help, before any dispatch/side effect.
# 'mode' handles its own -h/--help; an empty/help verb falls through to grouped help.
case "${1:-}" in
  -h|--help)
    case "${cmd}" in
      ""|help|mode) : ;;
      *) if _verb_help "${cmd}"; then exit 0; fi ;;
    esac
    ;;
esac

case "${cmd}" in
  up)
    if [ -n "${HM_PRINT:-}" ]; then echo "${SCRIPTS}/start-all.sh"; exit 0; fi
    # First-run wiring on demand: `hm up --setup` copies the config trinity.
    case " $* " in *" --setup "*) [ -f "${SCRIPTS}/setup.sh" ] && "${SCRIPTS}/setup.sh" || true ;; esac
    # free_uplift toggle (plugins/free_uplift)
    case " $* " in *" --free-uplift "*) _set_uplift true ;; *" --no-free-uplift "*) _set_uplift false ;; esac
    # Posture: an explicit --<mode> flag switches; no flag keeps the persisted
    # posture (default 'free' on first run) and never silently escalates to paid.
    _m="$(_inf_mode_from_args "$@")"
    if [ -n "${_m}" ]; then _apply_inf_mode "${_m}"
    else _apply_inf_mode "$(_inf name 2>/dev/null || echo free)"; fi
    # Raise Hermes' own MCP call timeouts (the 120s long-run killer) before the
    # stack comes up — idempotent, no-op once applied. Never fails `hm up`.
    [ -f "${SCRIPTS}/fix-hermes-timeouts.sh" ] && \
      "${SCRIPTS}/fix-hermes-timeouts.sh" || true
    "${SCRIPTS}/start-all.sh"
    # If the conductor was already running, restart it so it picks up the new mode
    # (mode is read from CONDUCTOR_MODE in .env at launch). No-op if mode unchanged.
    if [ "${HMX_MODE_CHANGED}" = "1" ] && timeout 1 bash -c ">/dev/tcp/127.0.0.1/${MCP_ESCALATION_PORT:-9105}" 2>/dev/null; then
      echo "  • mode changed → restarting conductor (escalation) to apply it"
      "${SCRIPTS}/restart.sh" escalation >/dev/null 2>&1 || true
    fi
    # embed (:8002) + rerank (:8003) serves auto-start with the stack on gpu_local
    # (the dense lane + reranker); opt out with HM_WITH_EMBED=0 / HM_WITH_RERANK=0.
    _start_serves
    # roster: warn (never gate) if a configured model id is deprecated/missing
    ( cd "${REPO_ROOT}" && python3 -m lib.inference.roster --warn-only 2>/dev/null ) || true
    # plugins: register optional capabilities (free_uplift) if their conditions hold
    ( cd "${REPO_ROOT}" && python3 -m plugins.load_plugins 2>/dev/null ) || true
    # ── one-screen start summary: mode + role satisfiability + present providers.
    #    (The Hermes backend was printed above by set_mode; roster warnings too.)
    echo
    echo "════════ hermes-max is up ════════"
    ( cd "${REPO_ROOT}" && python3 -m lib.inference.modes_cli show ) 2>/dev/null || true
    echo "  providers present (a missing key silently drops that rung):"
    ( cd "${REPO_ROOT}" && python3 -m lib.inference.modes_cli providers ) 2>/dev/null \
      | awk 'NR==1{next} {printf "    %-16s %s\n", $1, $2 $3}' || true
    echo "  next:  hermes   (or: hm dev for the cockpit · hm status · hm cost)"
    ;;
  mode)
    sub="${1:-}"
    case "${sub}" in
      ""|show)      _inf show ;;
      --list|list)  _inf list ;;
      -h|--help)    echo "hm mode [show|--list|<name>]   names: $(_inf list 2>/dev/null | sed -n '2,7p' | awk '{print $1}' | tr '\n' ' ')" ;;
      *)
        if [ -n "${HM_PRINT:-}" ]; then echo "hm mode set ${sub}"; exit 0; fi
        _apply_inf_mode "${sub}" || exit 2
        # If the conductor is already running, restart it so the new ceiling applies.
        if [ "${HMX_MODE_CHANGED}" = "1" ] && timeout 1 bash -c ">/dev/tcp/127.0.0.1/${MCP_ESCALATION_PORT:-9105}" 2>/dev/null; then
          echo "  • restarting conductor (escalation) to apply the new ceiling"
          "${SCRIPTS}/restart.sh" escalation >/dev/null 2>&1 || true
        fi
        ;;
    esac
    ;;
  down)        _stop_ui; _dispatch "${SCRIPTS}/stop-all.sh" "$@" ;;
  stop)        if [ -n "${HM_PRINT:-}" ]; then echo "stop ui + ${SCRIPTS}/stop-all.sh"; exit 0; fi
               _stop_ui; "${SCRIPTS}/stop-all.sh" "$@" ;;
  restart)     _dispatch "${SCRIPTS}/restart.sh" "$@" ;;
  status)      _dispatch "${SCRIPTS}/status.sh" "$@" ;;
  watch)       _dispatch "${SCRIPTS}/watch.sh" "$@" ;;
  observe)     _dispatch "${SCRIPTS}/observe.sh" "$@" ;;
  health)      _dispatch "${SCRIPTS}/healthcheck.sh" "$@" ;;
  preflight)   _dispatch "${SCRIPTS}/preflight.sh" "$@" ;;
  smoke)       _dispatch "${SCRIPTS}/integration-smoke.sh" "$@" ;;
  ui-test)     _dispatch "${SCRIPTS}/ui-actuation-test.sh" "$@" ;;
  regression)  _dispatch "${SCRIPTS}/regression-eval.sh" "$@" ;;
  summary)     _dispatch "${SCRIPTS}/run-summary.sh" "$@" ;;
  bottleneck)  _dispatch "${SCRIPTS}/bottleneck-eval.sh" "$@" ;;
  cost)
    if [ -n "${HM_PRINT:-}" ]; then echo "lib.inference cost + ${SCRIPTS}/conductor-report.sh"; exit 0; fi
    ( cd "${REPO_ROOT}" && python3 -m lib.inference.modes_cli cost "$@" ) || true
    if [ -f "${SCRIPTS}/conductor-report.sh" ]; then
      echo; echo "── legacy conductor ledger ──"; "${SCRIPTS}/conductor-report.sh" || true
    fi
    ;;
  eval)        _dispatch "${SCRIPTS}/eval-battery.sh" "$@" ;;
  snapshot)    _dispatch "${SCRIPTS}/snapshot-stores.sh" "$@" ;;
  restore)     _dispatch "${SCRIPTS}/restore-stores.sh" "$@" ;;
  logs)
    srv="${1:-live}"
    if [ "${srv}" = "live" ]; then f="${LOG_DIR}/live.log"; else f="${LOG_DIR}/${srv#mcp-}.log"; fi
    if [ -n "${HM_PRINT:-}" ]; then echo "tail -F ${f}"; exit 0; fi
    [ -f "${f}" ] || { echo "no log at ${f}"; exit 1; }
    exec tail -n "${HM_LOG_LINES:-60}" -F "${f}"
    ;;
  run)
    if [ -n "${HM_PRINT:-}" ]; then echo "hermes $*"; exit 0; fi
    command -v hermes >/dev/null 2>&1 || { echo "✗ 'hermes' not on PATH — install/activate Hermes first."; exit 127; }
    # Raw hermes flags (e.g. `hm run --continue …`) pass straight through.
    case "${1:-}" in -*) exec hermes "$@" ;; esac
    _hm_prompt="$*"
    _hm_plan="${PWD}/PLAN.md"
    # Escape hatch: HM_NO_PREPLAN=1 runs the legacy raw-prompt path (no enforced split).
    if [ -n "${HM_NO_PREPLAN:-}" ]; then exec hermes --yolo -z "${_hm_prompt}"; fi
    # Fix 5: register the run so the web UI discovers it within ~1s (works without the
    # shell wrapper; .env sourced so the registry has the mode).
    _hm_run_id=""
    if [ -f "${SCRIPTS}/register_run.py" ]; then
      _hm_run_id="$( ( set -a; [ -f "${HMX_ENV_FILE}" ] && . "${HMX_ENV_FILE}" 2>/dev/null; set +a
                       python3 "${SCRIPTS}/register_run.py" "${PWD}" -z "${_hm_prompt}" ) 2>/dev/null )"
      export HM_CURRENT_RUN_ID="${_hm_run_id}"
    fi
    # Fix 3: conductor plans FIRST; preplan ALWAYS leaves a PLAN.md (signed, or a minimal
    # local-fallback if every rung 429'd after retries) so the run never dead-ends.
    if [ -f "${SCRIPTS}/preplan.py" ]; then
      ( set -a; [ -f "${HMX_ENV_FILE}" ] && . "${HMX_ENV_FILE}" 2>/dev/null; set +a
        python3 "${SCRIPTS}/preplan.py" "${PWD}" "${_hm_prompt}" ) || true
    fi
    if ! grep -qiE '^##[[:space:]]*Plan authored by:.*via conductor' "${_hm_plan}" 2>/dev/null; then
      echo "  ⚠ PLAN.md not conductor-signed (conductor unavailable) — proceeding; verify warns, not blocks."
    fi
    # The EXECUTION instruction hermes receives — NEVER the raw design brief (this is what
    # enforces the split). Names the mid-loop tools: reasoning_escalation (stuck/HIGH) and
    # review_and_adapt (a step is impossible as written).
    _hm_exec="Read PLAN.md in ${PWD} first, then execute it. Do NOT replan or redesign — the architecture is already decided in PLAN.md. Execute each step. For any step marked 'complexity: HIGH', call reasoning_escalation BEFORE implementing it and follow the guidance. If a step proves IMPOSSIBLE as written, call review_and_adapt with the issue and step number — do not attempt impossible implementations and do not spin. If you get stuck, call reasoning_escalation rather than over-reasoning — ask and act. Verify with pytest; done when the plan's DONE_CONDITION is met."
    # ── interactive default: exec into native hermes, which OWNS the terminal ──
    # `exec` replaces this process with hermes — no subprocess, no pipe, no blank
    # screen. Hermes streams natively (tokens, tool_progress, banner). The registered
    # run keeps the SAME pid (exec), so the UI's pid-liveness marks it done on exit.
    # (Native one-shot; the run is autonomous + the conductor plugin orchestrates. For
    # the interactive REPL with slash-commands, run `hermes chat` in this dir directly.)
    if [ "${HM_HEADLESS:-0}" = "0" ]; then
      exec hermes --yolo -z "${_hm_exec}"
    fi
    # ── headless (CI/cron): tmux window so a non-interactive caller doesn't block ──
    _hm_pf="$(mktemp 2>/dev/null || echo /tmp/hmx_exec.$$)"; printf '%s' "${_hm_exec}" > "${_hm_pf}"
    _hm_done="python3 '${SCRIPTS}/complete_run.py' '${_hm_run_id}' 2>/dev/null"
    if command -v tmux >/dev/null 2>&1; then
      _win="run-$(basename "${PWD}")-$(date +%H%M%S 2>/dev/null || echo run)"
      _cmd="cd '${PWD}' && hermes --yolo -z \"\$(cat '${_hm_pf}')\"; rm -f '${_hm_pf}'; ${_hm_done}; echo '--- done ---'; read _"
      tmux new-window -t "${TMUX_SESSION}" -n "${_win}" "${_cmd}" 2>/dev/null \
        || tmux new-session -d -s "${TMUX_SESSION}" -n "${_win}" "${_cmd}"
      echo "✓ headless run in tmux '${TMUX_SESSION}:${_win}' — attach: tmux attach -t ${TMUX_SESSION}"
      exit 0
    fi
    # headless, no tmux: run inline to completion.
    hermes --yolo -z "${_hm_exec}"; _rc=$?
    rm -f "${_hm_pf}"; [ -n "${_hm_run_id}" ] && python3 "${SCRIPTS}/complete_run.py" "${_hm_run_id}" 2>/dev/null
    exit ${_rc}
    ;;
  setup)   _dispatch "${SCRIPTS}/setup.sh" "$@" ;;
  ui)
    if [ -n "${HM_PRINT:-}" ]; then echo "python3 -m ui.server $*"; exit 0; fi
    command -v python3 >/dev/null 2>&1 || { echo "✗ python3 not found — required for 'hm ui'."; exit 127; }
    if [ ! -f "${REPO_ROOT}/ui/web/dist/index.html" ]; then
      echo "  • frontend not built yet — building once (cd ui/web && npm install && npm run build)…"
      if command -v npm >/dev/null 2>&1; then
        ( cd "${REPO_ROOT}/ui/web" && npm install --no-fund --no-audit >/dev/null 2>&1 && npm run build >/dev/null 2>&1 ) \
          || echo "  ⚠ frontend build failed — the server still runs and the API works; build manually in ui/web."
      else
        echo "  ⚠ npm not found — the server runs and the API works, but the page needs 'npm run build' in ui/web."
      fi
    fi
    cd "${REPO_ROOT}" && exec python3 -m ui.server "$@"
    ;;
  dev)     _dev_daemon "$@" ;;
  cockpit) _dev "$@" ;;
  attach)  _attach ;;
  install) _install ;;
  ""|-h|--help|help) usage "$@" ;;
  *) echo "hm: unknown verb '${cmd}'"; echo; _help_short; exit 2 ;;
esac
