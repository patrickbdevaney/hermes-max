migration/
.env
# vendored browser binaries (Lightpanda ~130MB / Obscura ~80MB) — fetched per-host,
# never committed (see .env.example LIGHTPANDA_BIN / OBSCURA_BIN). Tracked helper
# scripts in bin/ are allow-listed below.
bin/*
!bin/hm-native
# runtime config + state dir — the system reads live config from here (or
# $HERMES_MAX_CONFIG_DIR); the repo ships only config/*.example.yaml. Never commit.
.hermes-max/
# conductor runtime scratch dir — local state, never committed.
.hermes-conductor/
# conductor-authored plan + archived history (runtime artifacts of a task run here)
/PLAN.md
/plans/
.mypy_cache/
__pycache__/
.ruff_cache/
.venv/
venv/
*.pyc
*.pyo
*.db
*.db-wal
*.db-shm
.pytest_cache/
*.egg-info/
dist/
build/
node_modules/
.DS_Store
*.log

# conductor config backups (Stage edits)
.conductor-backup/
conductor.yaml

.env.bak.*

# corpus and generated run artifacts. These are regenerated at the repo ROOT by
# the hm verbs (hm bottleneck, hm eval, the dry-run/research harnesses); the
# leading slash ignores only those fresh root copies. The captured provenance
# copies under archive/traces/ ARE tracked (see archive/traces/README.md).
corpus/
/dry_run_trace.md
/deep_research_trace.md
/eval_battery_report.md
/emergent_eval_report.md
/bottleneck_report.md
/rate_limit_validation_trace.md
replacements.txt

# hermes runtime state (if not already in ~/.hermes-max)
*.sqlite
*.db-wal
*.db-shm

# vllm / model serving — the runtime pidfile dir is ~/.hermes-max/run (outside the
# repo). Anchor to the repo root so a bare `run/` rule can't silently swallow source
# dirs named run/ (e.g. ui/web/src/components/run/, the Run-view components).
*.pid
/run/

# local scratch / one-off artifacts (machine-specific)
restore_products.txt
vendor/
.serena/

# generated full-repo dump (repo_dump.py) — large artifact, not tracked
repo_dump.md
